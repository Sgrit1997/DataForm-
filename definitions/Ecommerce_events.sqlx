config {
  type: "view",
  database: 'progetto-cloud-test-hrm',
  schema: 'analytics_431901473',
  name: 'Ecommerce_events',
  tags: ["ga4", "raw", "events"],
  description: "Vista RAW degli eventi GA4 filtrata sulla target date"
}
 
SELECT 
   * 
FROM ${ref("clean_data")}
WHERE
    event_name in ("add_to_cart", "purchase", "select_item")
 